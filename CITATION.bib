@misc{khan2025hndsr,
  title        = {HNDSR: A Hybrid Neural Operator--Diffusion Model for Continuous-Scale Satellite Image Super-Resolution},
  author       = {Khan, Adil and Modanwal, Rakshit and Vardhan, Harsh and Jain, Piyush and Vikram, Yash},
  year         = {2025},
  month        = {December},
  institution  = {Department of Computer Science and Engineering, IIIT Nagpur},
  address      = {Nagpur, Maharashtra, India},
  note         = {Unpublished Mini-Project under supervision of Mr. Adil Khan. Session: July-December 2025},
  howpublished = {\url{https://github.com/The-Harsh-Vardhan/HNDSR}},
  keywords     = {satellite image super-resolution, neural operator, diffusion model, continuous scale, remote sensing},
  abstract     = {Super-resolution (SR) of satellite imagery remains a fundamental challenge in remote sensing, requiring models that support flexible scaling and high perceptual fidelity. This research introduces a novel hybrid model, HNDSR (Hybrid Neural Operator--Diffusion Super-Resolution), that combines a continuous functional prior learnt using a neural operator with a latent diffusion network to reconstruct high-resolution satellite pictures. The neural operator module converts low-resolution inputs into resolution-agnostic feature maps that preserve spatial structure, and the diffusion model uses these priors and scale conditions to produce texture-rich, structurally coherent outputs. Training uses paired low- and high-resolution photos from the open-access 4x Satellite Image Super-Resolution dataset on Kaggle. Experimental results show that HNDSR outperforms contemporary continuous-scale SR techniques in terms of PSNR, SSIM, and LPIPS.}
}

